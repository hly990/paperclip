# Paperclip reads only DATABASE_URL for PostgreSQL (see server/src/config.ts).
# DATABASE_HOST, DATABASE_PORT, DATABASE_NAME, DATABASE_USER, and DATABASE_PASSWORD
# are not read by the server—keep a single source of truth in DATABASE_URL so the
# database name in the path matches what you created in Postgres.
#
# One-time: create the empty database, then start the app (migrations run on startup):
#   psql "postgres://USER:PASSWORD@localhost:5432/postgres" -c "CREATE DATABASE paperclip;"
#
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
# Superuser-style URL (database name in the path must still be paperclip, or change both):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/paperclip

PORT=3100
SERVE_UI=false
